{
  "extends": "@fxhash/tsconfig/base",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test/**/*"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
    },
    "target": "es2022",
    "lib": ["es2022", "DOM"],
    // FIXME: resolve type errors when removing the following lines
    "strict": false,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
  },
}
